<html>
    <head>
    <style>
        body{
            background-color: rgb(37, 37, 37);
            font-family:'roboto', 'sans-serif' ;
            margin: 0%;
            color: var(--light);
            overflow-x: hidden;
        }
        :root {
            --primary: #d90429;
            --dark: #111;
            --light: #edf2f4;
            --transition: all 0.3s ease;
        }
        nav {
            background: rgba(17, 17, 17, 0.95);
            padding: 20px;
            display: flex;
            justify-content: space-around;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 2px solid var(--primary);
            backdrop-filter: blur(10px);
        }
    </style>
    </head>
</html>